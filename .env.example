# AetherVerse 本地开发环境变量模板
# 复制为 .env 并填入实际值: cp .env.example .env

# ============================================================
# 数据库
# ============================================================
DATABASE_URL=postgresql+asyncpg://aetherverse:dev_password_change_me@localhost:5432/aetherverse

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# RabbitMQ
# ============================================================
RABBITMQ_URL=amqp://aetherverse:dev_password_change_me@localhost:5672/

# ============================================================
# 对象存储 (MinIO / S3)
# ============================================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=aetherverse
S3_SECRET_KEY=dev_password_change_me
S3_BUCKET=aetherverse

# ============================================================
# JWT
# ============================================================
JWT_SECRET=change-this-to-a-random-256-bit-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================================
# SMS (短信服务)
# ============================================================
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=AetherVerse
SMS_TEMPLATE_CODE=

# ============================================================
# AI 模型 API Keys
# ============================================================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

ZHIPU_API_KEY=

# ============================================================
# 内部服务通信
# ============================================================
AI_ENGINE_URL=http://localhost:8001
INTERNAL_API_KEY=change-this-internal-key

# ============================================================
# AI 预算
# ============================================================
AI_DAILY_BUDGET_YUAN=100
AI_BUDGET_ALERT_THRESHOLD=0.80
